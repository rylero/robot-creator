package {{.Package}}.subsystems.{{.NameLower}};

import static edu.wpi.first.units.Units.*;
import static frc.robot.util.PhoenixUtil.tryUntilOk;

import com.ctre.phoenix6.StatusSignal;
import com.ctre.phoenix6.configs.TalonFXConfiguration;
{{- if gt .MotorCount 1}}
import com.ctre.phoenix6.controls.Follower;
{{- end}}
import com.ctre.phoenix6.controls.MotionMagicVoltage;
import com.ctre.phoenix6.controls.VoltageOut;
import com.ctre.phoenix6.hardware.ParentDevice;
import com.ctre.phoenix6.hardware.TalonFX;
import com.ctre.phoenix6.signals.NeutralModeValue;
import edu.wpi.first.units.measure.Angle;
import edu.wpi.first.units.measure.AngularVelocity;
import edu.wpi.first.units.measure.Current;
import edu.wpi.first.units.measure.Voltage;
import edu.wpi.first.wpilibj.Alert;
import edu.wpi.first.wpilibj.Alert.AlertType;
import frc.robot.util.AlertUtils;
import frc.robot.util.BetterStatusSignalCollection;

public class {{.Name}}IOTalonFX implements {{.Name}}IO {
  private final Alert statusSignalAlert =
      new Alert("ISSUE", "Status Signal Error", AlertType.kError);
  private final Alert configAlert =
      new Alert("CRITICAL", "Failed to Configure {{.Name}} Motor", AlertType.kError);

  private final TalonFX leader =
      new TalonFX({{.Name}}Constants.LEADER_ID, {{.Name}}Constants.CAN_BUS);
{{- range .Followers}}
  private final TalonFX follower{{.Index}} =
      new TalonFX({{$.Name}}Constants.FOLLOWER_{{.Index}}_ID, {{$.Name}}Constants.CAN_BUS);
{{- end}}

  private final StatusSignal<Angle> position;
  private final StatusSignal<AngularVelocity> velocity;
  private final StatusSignal<Voltage> appliedVoltage;
  private final StatusSignal<Current> leaderCurrent;
{{- range .Followers}}
  private final StatusSignal<Current> follower{{.Index}}Current;
{{- end}}
  private final BetterStatusSignalCollection statusSignalCollector;

  private final MotionMagicVoltage positionRequest = new MotionMagicVoltage(0).withSlot(0);
  private final VoltageOut voltageRequest = new VoltageOut(0);

  public {{.Name}}IOTalonFX() {
    var config = new TalonFXConfiguration();
    config.Feedback.SensorToMechanismRatio = {{.Name}}Constants.GEARING;
    config.MotorOutput.Inverted = {{.Name}}Constants.LEADER_DIRECTION;
    config.MotorOutput.NeutralMode = NeutralModeValue.Brake;
    config.Slot0 = {{.Name}}Constants.GAINS.toSlot0Configs();
    config.MotionMagic = {{.Name}}Constants.MOTION_MAGIC_CONFIGS;
    config.SoftwareLimitSwitch.ForwardSoftLimitEnable = true;
    config.SoftwareLimitSwitch.ForwardSoftLimitThreshold =
        {{.Name}}Constants.MAX_POSITION.in(Rotations);
    config.SoftwareLimitSwitch.ReverseSoftLimitEnable = true;
    config.SoftwareLimitSwitch.ReverseSoftLimitThreshold =
        {{.Name}}Constants.MIN_POSITION.in(Rotations);
    config.CurrentLimits.StatorCurrentLimitEnable = true;
    config.CurrentLimits.StatorCurrentLimit = 40;
    AlertUtils.processCriticalAlert(
        configAlert, !tryUntilOk(5, () -> leader.getConfigurator().apply(config)));
{{- range .Followers}}
    AlertUtils.processCriticalAlert(
        configAlert, !tryUntilOk(5, () -> follower{{.Index}}.getConfigurator().apply(config)));
{{- end}}
{{- range .Followers}}
    follower{{.Index}}.setControl(new Follower(leader.getDeviceID(), {{$.Name}}Constants.FOLLOWER_ALIGNMENT));
{{- end}}

    position = leader.getPosition();
    velocity = leader.getVelocity();
    appliedVoltage = leader.getMotorVoltage();
    leaderCurrent = leader.getSupplyCurrent();
{{- range .Followers}}
    follower{{.Index}}Current = follower{{.Index}}.getSupplyCurrent();
{{- end}}
    position.setUpdateFrequency(50);
    velocity.setUpdateFrequency(50);
    appliedVoltage.setUpdateFrequency(20);
    leaderCurrent.setUpdateFrequency(20);
{{- range .Followers}}
    follower{{.Index}}Current.setUpdateFrequency(20);
{{- end}}
    statusSignalCollector =
        new BetterStatusSignalCollection(
            position, velocity, appliedVoltage, leaderCurrent{{range .Followers}}, follower{{.Index}}Current{{end}});
    ParentDevice.optimizeBusUtilizationForAll(leader{{range .Followers}}, follower{{.Index}}{{end}});
  }

  @Override
  public void updateInputs({{.Name}}IOInputs inputs) {
    statusSignalCollector.refreshAll();
    if (!statusSignalCollector.isAllGood()) {
      statusSignalAlert.set(true);
      statusSignalAlert.setText(
          "{{.Name}} TalonFX Status Signal Error: "
              + statusSignalCollector.getBadSignalsString());
    } else {
      statusSignalAlert.set(false);
    }
    inputs.leaderConnected = position.getStatus().isOK();
{{- range .Followers}}
    inputs.follower{{.Index}}Connected = follower{{.Index}}Current.getStatus().isOK();
{{- end}}
    inputs.position = position.getValue();
    inputs.velocity = velocity.getValue();
    inputs.appliedVoltage = appliedVoltage.getValue();
    inputs.leaderSupplyCurrent = leaderCurrent.getValue();
{{- range .Followers}}
    inputs.follower{{.Index}}SupplyCurrent = follower{{.Index}}Current.getValue();
{{- end}}
  }

  @Override
  public void setPosition(Angle position) {
    leader.setControl(positionRequest.withPosition(position));
  }

  @Override
  public void setVoltage(Voltage volts) {
    leader.setControl(voltageRequest.withOutput(volts));
  }

  @Override
  public void setBrakeMode(boolean brake) {
    var mode = brake ? NeutralModeValue.Brake : NeutralModeValue.Coast;
    leader.setNeutralMode(mode);
{{- range .Followers}}
    follower{{.Index}}.setNeutralMode(mode);
{{- end}}
  }
}
